# Django Configuration
DEBUG=False
SECRET_KEY=change-this-to-a-secure-random-key-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Database
DATABASE_URL=sqlite:///db.sqlite3
MONGODB_URI=mongodb://mongodb:27017/dealershipsDB

# API URLs
BACKEND_URL=http://api_server:3030
SENTIMENT_ANALYZER_URL=http://sentiment_analyzer:5000/

# Node.js API
NODE_ENV=production
MONGO_URL=mongodb://mongodb:27017/dealershipsDB

# Flask Sentiment Analyzer
FLASK_ENV=production

# React Frontend
REACT_APP_API_URL=http://localhost:8000

# Email Configuration (Optional)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password

# AWS S3 Configuration (Optional - for production file storage)
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_STORAGE_BUCKET_NAME=your-bucket
# AWS_S3_REGION_NAME=us-east-1
